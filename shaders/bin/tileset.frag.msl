#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct main0_out
{
    float4 out_var_SV_Target [[color(0)]];
};

struct main0_in
{
    float2 in_var_TEXCOORD0 [[user(locn0)]];
};

fragment main0_out main0(main0_in in [[stage_in]], texture2d<float> OverlayTexture [[texture(0)]], sampler OverlaySampler [[sampler(0)]])
{
    main0_out out = {};
    out.out_var_SV_Target = OverlayTexture.sample(OverlaySampler, in.in_var_TEXCOORD0);
    return out;
}

